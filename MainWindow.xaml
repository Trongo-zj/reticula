<Window x:Class="ReticulaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReticulaApp"
        mc:Ignorable="d"
        Title="Lanzador de aplicaciones"
        MinWidth="640"
        MinHeight="520"
        Background="#FFFFFFFF"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#004B76"/>
        <SolidColorBrush x:Key="MainText" Color="#171717"/>
        <SolidColorBrush x:Key="ButtonText" Color="#FFFFFFFF"/>
        <Style x:Key="TileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource ButtonText}"/>
            <Setter Property="FontFamily" Value="Gill Sans MT, Gill Sans, Segoe UI, sans-serif"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#33000000" BlurRadius="8" Direction="270" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource ButtonText}" Margin="24" AllowDrop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Vertical">
            <TextBlock Text="Lanzador de aplicaciones"
                       Foreground="{StaticResource MainText}"
                       FontFamily="Gill Sans MT, Gill Sans, Segoe UI, sans-serif"
                       FontSize="28"
                       FontWeight="Light"/>
            <TextBlock Text="Arrastra accesos directos, ejecutables o entradas del menú Inicio. Arrastra fuera para eliminar."
                       Foreground="{StaticResource MainText}"
                       FontFamily="Gill Sans MT, Gill Sans, Segoe UI, sans-serif"
                       FontSize="14"
                       Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{StaticResource ButtonText}"
                Padding="16"
                CornerRadius="12"
                BorderBrush="#11000000"
                BorderThickness="1"
                AllowDrop="True"
                Drop="GridContainer_Drop"
                DragEnter="GridContainer_DragEnter"
                DragOver="GridContainer_DragOver"
                MouseLeftButtonDown="GridContainer_MouseLeftButtonDown">
            <ItemsControl ItemsSource="{Binding Tiles}"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="6" Rows="5" Margin="0" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource TileButtonStyle}"
                                Content="{Binding}"
                                AllowDrop="True"
                                Click="TileButton_Click"
                                Drop="TileButton_Drop"
                                DragEnter="TileButton_DragEnter"
                                DragOver="TileButton_DragOver"
                                PreviewMouseDoubleClick="TileButton_PreviewMouseDoubleClick"
                                PreviewMouseLeftButtonDown="TileButton_PreviewMouseLeftButtonDown"
                                PreviewMouseMove="TileButton_PreviewMouseMove">
                            <Button.Tag>
                                <Binding Path="Id"/>
                            </Button.Tag>
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Viewbox Margin="0,0,0,8" Stretch="Uniform" Grid.Row="0">
                                            <Grid>
                                                <Image Source="{Binding Icon}"
                                                       Width="64"
                                                       Height="64"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasApp}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <TextBlock Text="+"
                                                           FontSize="48"
                                                           Foreground="{StaticResource ButtonText}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasApp}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Viewbox>
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding DisplayName, TargetNullValue='Vacío'}"
                                                   FontFamily="Gill Sans MT, Gill Sans, Segoe UI, sans-serif"
                                                   Foreground="{StaticResource ButtonText}"
                                                   FontSize="18"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   Margin="4,0,4,0"/>
                                    </Grid>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>
