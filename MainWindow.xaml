<Window x:Class="ReticulaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ReticulaApp"
        mc:Ignorable="d"
        Title="Lanzador de aplicaciones"
        MinWidth="640"
        MinHeight="520"
        Background="#FFFFFFFF"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver"
        FontFamily="{DynamicResource {x:Static SystemFonts.MessageFontFamilyKey}}">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#004B76"/>
        <SolidColorBrush x:Key="MainText" Color="#171717"/>
        <SolidColorBrush x:Key="ButtonText" Color="#FFFFFFFF"/>
        <Style x:Key="TileButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource ButtonText}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#33000000" BlurRadius="8" Direction="270" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryBlue}"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
    </Window.Resources>
    <Grid Background="{StaticResource ButtonText}" Margin="24" AllowDrop="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Lanzador de aplicaciones"
                    Foreground="{StaticResource MainText}"
                    FontSize="28"
                    FontWeight="Light"/>
                <TextBlock Text="Arrastra accesos directos, ejecutables o entradas del menú Inicio. Arrastra fuera para eliminar."
                    Foreground="{StaticResource MainText}"
                    FontSize="14"
                    Margin="0,6,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="16,0,0,0">
                <Button Content="Exportar cuadrícula"
                        Style="{StaticResource HeaderButtonStyle}"
                        Click="ExportButton_Click"/>
                <Button Content="Importar cuadrícula"
                        Style="{StaticResource HeaderButtonStyle}"
                        Margin="8,0,0,0"
                        Click="ImportButton_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource ButtonText}"
                Padding="16"
                CornerRadius="12"
                BorderBrush="#11000000"
                BorderThickness="1"
                AllowDrop="True"
                Drop="GridContainer_Drop"
                DragEnter="GridContainer_DragEnter"
                DragOver="GridContainer_DragOver"
                MouseLeftButtonDown="GridContainer_MouseLeftButtonDown">
            <ItemsControl ItemsSource="{Binding Tiles}"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="6" Rows="5" Margin="0" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource TileButtonStyle}"
                                Background="{Binding ColumnBrush}"
                                Content="{Binding}"
                                AllowDrop="True"
                                Click="TileButton_Click"
                                Drop="TileButton_Drop"
                                DragEnter="TileButton_DragEnter"
                                DragOver="TileButton_DragOver"
                                PreviewMouseDoubleClick="TileButton_PreviewMouseDoubleClick"
                                PreviewMouseLeftButtonDown="TileButton_PreviewMouseLeftButtonDown"
                                PreviewMouseMove="TileButton_PreviewMouseMove">
                            <Button.Tag>
                                <Binding Path="Id"/>
                            </Button.Tag>
                            <Button.ContentTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource ButtonText}"
                                                   FontSize="16"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   Margin="4,0,4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasApp}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </Button.ContentTemplate>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>
